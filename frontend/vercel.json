{
  "buildCommand": "npm install && node node_modules/vite/bin/vite.js build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://staynear-davp.onrender.com/api/$1" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
